# ============================================================
#  DVSA Slot Monitor - Environment Variables TEMPLATE
#  Copy this file to .env and fill in your real values.
# ============================================================

# --- DVSA Portal Credentials ---
DVSA_USERNAME=YOUR_USERNAME_HERE
DVSA_PASSWORD=YOUR_PASSWORD_HERE

# --- Telegram Alerts (RECOMMENDED) ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# --- WhatsApp Alerts via Twilio (OPTIONAL) ---
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_WHATSAPP_FROM=+14155238886
WHATSAPP_TO_NUMBER=+447XXXXXXXXX
